# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Data — never commit raw MRI files
data/
datasets/
*.nii
*.nii.gz
*.mha
*.mhd
*.npy
*.npz

# Model outputs and checkpoints
outputs/
logs/
runs/
nnunet_workspace/
wandb/

# Manifests with absolute paths (legacy format — case-ID manifests ARE committed)
# manifests/ is intentionally tracked; only exclude machine-specific overrides
manifests/local_*.json

# Weights cache
.cache/

# Paper build artifacts
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz
paper/main.pdf
# figures PDFs are committed (they are generated assets, not build artifacts)
paper/figures/*.aux
paper/figures/*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
